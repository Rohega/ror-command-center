#!/usr/bin/env bash
# RoR Command Center — rorcc CLI
# Local AI bootstrap: scaffold projects and run the Rails specialist team on Ollama.
set -euo pipefail

# Resolve the directory of this script, following symlinks (curl-mode installs
# rorcc into PATH, so we cannot assume CWD).
_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
RORCC_BIN_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
RORCC_HOME="$(cd "$RORCC_BIN_DIR/.." && pwd)"
RORCC_LIB_DIR="$RORCC_HOME/lib/rorcc"

# shellcheck source=/dev/null
. "$RORCC_LIB_DIR/common.sh"

usage() {
  cat <<'EOF'
rorcc — RoR Command Center local AI CLI

USAGE:
  rorcc [command] [args]      (no command → interactive menu)

COMMANDS:
  menu                    Interactive launcher: pick a specialist by number
  init <project>          Scaffold a new project with the .ai/ framework
  doctor                  Check Ollama, models, and environment
  build-agent <name>      Compile a .ai/agents/<name>.yaml into an Ollama model
  update [name]           Recompile agents after editing .ai/ (all, or just <name>)
  agent <name>            Chat locally with a compiled agent (needs build-agent first)
  help                    Show this help

ENVIRONMENT:
  RORCC_MODEL   Base Ollama model (default: qwen2.5-coder:7b)
  OLLAMA_HOST   Ollama endpoint (default: http://localhost:11434)

EXAMPLES:
  rorcc init warehouse-wms
  rorcc doctor
  rorcc build-agent rails-architect
  rorcc agent rails-architect
EOF
}

cmd_init() {
  local target="${1:-}"
  if [ -z "$target" ]; then
    err "usage: rorcc init <project-dir>"
    return 2
  fi
  local installer="$RORCC_HOME/install.sh"
  if [ ! -f "$installer" ]; then
    err "install.sh not found at $installer"
    return 1
  fi
  info "Scaffolding '$target' via install.sh"
  "$installer" "$target"
  printf '\n'
  ok "next: cd $target && rorcc doctor"
}

main() {
  # No command → friendly interactive menu (built for non-technical users).
  local cmd="${1:-menu}"
  [ $# -gt 0 ] && shift || true
  case "$cmd" in
    menu)         . "$RORCC_LIB_DIR/menu.sh";        cmd_menu "$@" ;;
    init)         cmd_init "$@" ;;
    doctor)       . "$RORCC_LIB_DIR/doctor.sh";      cmd_doctor "$@" ;;
    build-agent)  . "$RORCC_LIB_DIR/build_agent.sh"; cmd_build_agent "$@" ;;
    update)       . "$RORCC_LIB_DIR/build_agent.sh"; cmd_update "$@" ;;
    agent)        . "$RORCC_LIB_DIR/agent.sh";       cmd_agent "$@" ;;
    help|-h|--help) usage ;;
    *) err "unknown command: $cmd"; printf '\n'; usage; exit 2 ;;
  esac
}

main "$@"
